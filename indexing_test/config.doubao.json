{
  "excel": {
    "path": "./data/prompts.xlsx",
    "sheet": "Sheet1",
    "header_row": 1,
    "prompt_column": "prompt",
    "result_column": "result",
    "source_column": "sources",
    "start_row": 2,
    "skip_completed": true
  },
  "browser": {
    "start_url": "https://www.doubao.com/chat/",
    "user_data_dir": "./browser-profile-doubao",
    "channel": "chrome",
    "headless": false,
    "startup_wait_ms": 3000,
    "action_timeout_ms": 15000
  },
  "chat": {
    "platform_name": "doubao",
    "input_selectors": [
      "textarea.semi-input-textarea[placeholder]",
      "textarea.semi-input-textarea",
      "textarea"
    ],
    "send_button_selectors": [],
    "response_selectors": [
      ".flow-markdown-body",
      "[class~='flow-markdown-body']"
    ],
    "new_chat_selectors": [
      "text=新对话",
      "button:has-text('新对话')"
    ],
    "loading_selectors": [
      ".semi-spin-spinning",
      "[aria-busy='true']",
      "[class*='loading']"
    ],
    "popup_selectors": [
      "[role='dialog']",
      "[aria-modal='true']",
      ".semi-modal-wrap"
    ],
    "popup_confirm_selectors": [
      "[role='dialog'] button:has-text('继续')",
      "[role='dialog'] button:has-text('确定')",
      "[role='dialog'] button:has-text('确认')",
      "[role='dialog'] button:has-text('我知道了')",
      "[role='dialog'] button:has-text('同意')",
      "[role='dialog'] button:has-text('开始使用')",
      ".semi-modal-wrap button:has-text('继续')",
      ".semi-modal-wrap button:has-text('确定')",
      ".semi-modal-wrap button:has-text('确认')"
    ],
    "response_timeout_seconds": 180,
    "stability_checks": 3,
    "poll_interval_seconds": 1.0,
    "send_hotkey": "Enter",
    "clear_input_hotkey": "Control+A",
    "new_chat_each_prompt": true,
    "manual_login": true,
    "manual_popup_confirmation": true
  }
}
